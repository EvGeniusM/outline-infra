URL=http://app.localhost
FORCE_HTTPS=false
PORT=3000
NODE_ENV=production
FILE_STORAGE=s3
FILE_STORAGE_UPLOAD_MAX_SIZE=26214400
SECRET_KEY=__GENERATE__
UTILS_SECRET=__GENERATE__

POSTGRES_USER=outline
POSTGRES_PASSWORD=outline_local_pw
POSTGRES_DB=outline
DATABASE_URL=postgres://outline:outline_local_pw@postgres:5432/outline
PGSSLMODE=disable

REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_local_pw
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin_local_pw
AWS_REGION=us-east-1
AWS_S3_UPLOAD_BUCKET_URL=http://files.localhost
AWS_S3_UPLOAD_BUCKET_NAME=outline
AWS_S3_FORCE_PATH_STYLE=true
AWS_S3_ACL=private

OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=oidc_local_secret
OIDC_AUTH_URI=http://auth.localhost/auth
OIDC_TOKEN_URI=http://auth.localhost/token
OIDC_USERINFO_URI=http://auth.localhost/userinfo
OIDC_USERNAME_CLAIM=email
OIDC_DISPLAY_NAME=Local Dex
OIDC_SCOPES=openid profile email

# --- Plane (Community Edition, AIO) ---
PLANE_URL=http://plane.localhost
PLANE_SECRET_KEY=__GENERATE__
LIVE_SERVER_SECRET_KEY=__GENERATE__
PLANE_DB=plane
PLANE_S3_BUCKET_NAME=plane-uploads

# RabbitMQ (брокер Celery для Plane)
RABBITMQ_USER=plane
RABBITMQ_PASSWORD=__GENERATE__
RABBITMQ_VHOST=plane
